root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_size = {{INDENT_SIZE}}

[*.py]
indent_style = space
indent_size = 4

[*.{js,ts,jsx,tsx,json,yaml,yml,md}]
indent_style = space
indent_size = 2

[*.dart]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
